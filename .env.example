# .env.example - Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://neuro_user:neuro_pass@postgres:5432/neuro_genomic

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=neuro-genomic-ecg

# API
API_SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-super-strong-secret-key-at-least-32-bytes-long-here-change-in-production-1234567890
API_DEBUG=True

# Environment
ENVIRONMENT=development
LOG_LEVEL=debug

# OCI (for production)
OCI_REGION=us-ashburn-1
OCI_TENANCY_OCID=ocid1.tenancy.oc1...
OCI_USER_OCID=ocid1.user.oc1...
OCI_FINGERPRINT=00:00:00...
OCI_PRIVATE_KEY_PATH=/path/to/key.pem

# JWT
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24